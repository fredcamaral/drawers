{
	"name": "pi-drawer-agents",
	"version": "0.1.0",
	"description": "Fire-and-forget background agents for pi — launch a task in a child pi session and pull its output later, without blocking the main loop.",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/fredcamaral/drawers.git",
		"directory": "packages/pi/background-agents"
	},
	"keywords": [
		"pi",
		"pi-package",
		"background-agents",
		"orchestration"
	],
	"pi": {
		"extensions": [
			"./src/index.ts"
		]
	},
	"files": [
		"src",
		"README.md"
	],
	"publishConfig": {
		"access": "public"
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": ">=0.79.0"
	},
	"dependencies": {
		"@drawers/pi-core": "workspace:*",
		"typebox": "1.1.38"
	},
	"devDependencies": {
		"@earendil-works/pi-coding-agent": "0.79.3",
		"bun-types": "1.3.14"
	}
}
